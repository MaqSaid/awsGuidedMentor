# GuidedMentor Frontend Environment Variables
# Copy to .env.local for local development
# In CI/CD these are injected from GitHub Actions vars (populated from Terraform outputs)

# API Gateway invoke URL (from terraform output: networking_outputs.api_gateway_url)
VITE_API_URL=http://localhost:5000

# Cognito User Pool ID (from terraform output: identity_outputs.user_pool_id)
VITE_COGNITO_USER_POOL_ID=ap-southeast-2_EXAMPLE

# Cognito App Client ID (from terraform output: identity_outputs.client_id)
VITE_COGNITO_CLIENT_ID=example123456

# AppSync GraphQL endpoint (from terraform output: engagement_outputs.appsync_url)
VITE_APPSYNC_URL=https://example.appsync-api.ap-southeast-2.amazonaws.com/graphql

# Environment name (dev, staging, prod)
VITE_ENVIRONMENT=dev

# Remote base URL for Module Federation (CloudFront domain for deployed environments)
# Local dev: leave empty or http://localhost (remotes load from individual dev servers)
# Deployed: https://{cloudfront-domain}/remotes (from terraform output: networking_outputs.cloudfront_domain)
VITE_REMOTE_BASE_URL=http://localhost
