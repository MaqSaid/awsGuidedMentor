{
  "enabled": true,
  "name": "Run Tests After Task",
  "description": "Runs the test suite after a spec task completes to verify implementation correctness",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "dotnet test GuidedMentor.sln --no-build --verbosity quiet --filter \"FullyQualifiedName~Tests\"",
    "timeout": 60
  }
}