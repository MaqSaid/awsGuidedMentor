{
  "enabled": true,
  "name": "Run Tests After Task",
  "description": "Runs unit tests (excluding integration) after a spec task completes to verify implementation correctness",
  "version": "3",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "dotnet test GuidedMentor.sln --no-build --verbosity quiet --filter \"FullyQualifiedName~Tests&FullyQualifiedName!~Integration\" -- RunConfiguration.MaxCpuCount=1",
    "timeout": 120
  }
}
