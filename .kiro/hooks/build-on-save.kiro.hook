{
  "enabled": true,
  "name": "Build on C# Save",
  "description": "Runs dotnet build when any C# file is saved to catch compile errors immediately",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.cs"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "dotnet build GuidedMentor.sln --no-restore --verbosity quiet",
    "timeout": 30
  }
}