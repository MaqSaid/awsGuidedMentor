{
  "name": "@guided-mentor/shared-test-utils",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./arbitraries": {
      "types": "./dist/arbitraries/index.d.ts",
      "default": "./dist/arbitraries/index.js"
    },
    "./integration": {
      "types": "./dist/integration/index.d.ts",
      "default": "./dist/integration/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@guided-mentor/shared-types": "*"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.490.0",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.490.0",
    "@aws-sdk/client-bedrock-runtime": "^3.490.0",
    "aws-sdk-client-mock": "^3.0.1",
    "fast-check": "^3.15.0",
    "vitest": "^1.2.0",
    "typescript": "^5.3.3",
    "@types/node": "^20.11.0"
  },
  "peerDependencies": {
    "fast-check": "^3.15.0",
    "vitest": "^1.2.0"
  }
}
